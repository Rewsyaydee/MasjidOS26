# ─────────────────────────────────────────────────────────────────────────
# MasjidOS 26 — environment template
# Copy to `.env.local` and fill in. Every key is OPTIONAL for local dev:
# missing keys just disable that feature (see lib/config.js capabilities).
# ─────────────────────────────────────────────────────────────────────────

# Where the app is served (used for OAuth redirects + ToyyibPay callbacks).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (auth + database + realtime) ───────────────────────────────
# Project Settings → API. The anon key is browser-safe; the service role key
# is SERVER-ONLY and bypasses RLS — never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Deepgram (live khutbah speech-to-text) — M6 ─────────────────────────
# Used server-side only to mint short-lived ephemeral tokens for the browser.
DEEPGRAM_API_KEY=

# ── Translation (live khutbah translation) — M6 ─────────────────────────
# Set EITHER one. LLM translation preserves Quranic register better than NMT.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── ToyyibPay (donations + live ticker) — M5 ────────────────────────────
# Sandbox: https://dev.toyyibpay.com  ·  Production: https://toyyibpay.com
TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=
